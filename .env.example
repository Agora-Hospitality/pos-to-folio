# ── MEWS Connector API ──────────────────────────────────────────────
MEWS_BASE_URL=https://api.mews.com
MEWS_CLIENT_TOKEN=your-client-token
MEWS_ACCESS_TOKEN=your-access-token
# Optional V2 access token (falls back to MEWS_ACCESS_TOKEN)
# MEWS_ACCESS_TOKEN_V2=
MEWS_CLIENT_NAME=AgoraPOSBridge

# Optionally set the F&B service and accounting category IDs directly.
# If not set, the bridge will try to auto-detect them from your MEWS configuration.
# MEWS_FB_SERVICE_ID=
# MEWS_FB_ACCOUNTING_CATEGORY_ID=

# Tax code for order items (defaults to Cyprus standard VAT)
# MEWS_TAX_CODE=CY-2024-1-S

# ── Goodtill / SumUp POS ───────────────────────────────────────────
GOODTILL_SUBDOMAIN=your-subdomain
GOODTILL_USERNAME=your-username
GOODTILL_PASSWORD=your-password

# ── Polling ─────────────────────────────────────────────────────────
# How often to poll for new sales (ms). Default: 60000 (1 minute)
POLL_INTERVAL_MS=60000
# How far back to look for sales on each poll (minutes). Default: 30
POLL_LOOKBACK_MINUTES=30

# ── Dead-letter (unpostable Guest Folio sales) ─────────────────────
# How long after first failure a sale keeps being retried (hours). Default: 24
# DEAD_LETTER_RETRY_WINDOW_HOURS=24
# Minimum gap between retries of one sale (ms). Default: 900000 (15 min)
# DEAD_LETTER_RETRY_INTERVAL_MS=900000
# Hard cap on retry attempts per sale. Default: 40
# DEAD_LETTER_MAX_ATTEMPTS=40
# Required to read GET /dead-letter (sent as the X-Bridge-Token header) —
# the payload contains guest names and amounts, so the endpoint is closed
# until this is set.
# BRIDGE_ADMIN_TOKEN=

# ── Server ──────────────────────────────────────────────────────────
PORT=3050
CURRENCY=EUR

# Directory for the persisted stores (processed-sales.json, dead-letter.json).
# These are the bridge's ONLY record of which POS sale maps to which MEWS order;
# void-reversal and double-post protection both depend on them surviving deploys.
# On Railway, create a Volume and mount it here (set the mount path to /data and
# DATA_DIR=/data) — otherwise the filesystem is ephemeral and every redeploy wipes
# the store, silently breaking void reversal. Defaults to ./data locally.
# DATA_DIR=/data

# ── MEWS Webhooks ───────────────────────────────────────────────────
# Secret for verifying MEWS webhook signatures (optional but recommended)
# MEWS_WEBHOOK_SECRET=

# ── Room Roster Sync ────────────────────────────────────────────────
# How often to run a full roster re-sync as a safety net (ms). Default: 600000 (10 min)
# ROSTER_RESYNC_INTERVAL_MS=600000
